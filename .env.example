# ============================================
# CONFIGURACIÓN SCHAP - TEMPLATE .env
# ============================================
# Renombrar este archivo a .env y ajustar los valores para su entorno.

# ========== ENTORNO ==========
FLASK_ENV=production

# ========== SERVIDOR BACKEND ==========
FLASK_HOST=0.0.0.0
FLASK_PORT=3000
FLASK_DEBUG=False

# ========== BASE DE DATOS POSTGRESQL ==========
DB_HOST=db
DB_PORT=5432
DB_NAME=schap_db
DB_USER=postgres
DB_PASSWORD=su_contraseña_segura_de_db

# ========== SEGURIDAD ==========
SECRET_KEY=su_clave_secreta_jwt_de_produccion
JWT_EXPIRATION_HOURS=8

# ========== EMPRESA ==========
COMPANY_NAME=SCHAP LTDA.
APP_NAME=SCHAP

# ========== EMAIL (SMTP) ==========
EMAIL_ENABLED=False
SMTP_HOST=smtp.ejemplo.cl
SMTP_PORT=587
SMTP_USER=notificaciones@ejemplo.cl
SMTP_PASSWORD=su_contraseña_smtp_aqui
SMTP_FROM=notificaciones@ejemplo.cl
SMTP_USE_TLS=True

# ========== USUARIO ADMINISTRADOR POR DEFECTO ==========
# Se inicializa de forma automática en el primer arranque si no existen usuarios administradores.
DEFAULT_ADMIN_EMAIL=admin@sistema.local
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=Administrador
